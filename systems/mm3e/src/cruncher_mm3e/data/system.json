  "pipeline": [
    {"stage": "per_rank", "formula": "if(base_cost_per_rank + sum_extras + sum_flaws >= 1, (base_cost_per_rank + sum_extras + sum_flaws) * ranks, max(1, per(ranks, max(1, 2 - (base_cost_per_rank + sum_extras + sum_flaws)))))"},
    {"stage": "flat", "formula": "max(1, prev + sum_flat)"},
    {"stage": "removable", "formula": "if(removable > 0, max(1, prev - per(prev, 5) * removable), prev)"}
  ],

