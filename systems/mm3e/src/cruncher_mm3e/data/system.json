  "derived": {
    "effective_str": "str + effect_enhanced_str",
    "effective_sta": "sta + effect_enhanced_sta",
    "effective_dex": "dex + effect_enhanced_dex",
    "effective_agl": "agl + effect_enhanced_agl",
    "effective_fgt": "fgt + effect_enhanced_fgt",
    "effective_int": "int + effect_enhanced_int",
    "effective_awe": "awe + effect_enhanced_awe",
    "effective_pre": "pre + effect_enhanced_pre",

    "dodge": "if(is_defenseless, 0, if(is_vulnerable, floor((effective_agl + ranks_dodge + bonus_dodge + effect_enhanced_dodge) / 2), effective_agl + ranks_dodge + bonus_dodge + effect_enhanced_dodge))",
    "parry": "if(is_defenseless, 0, if(is_vulnerable, floor((effective_fgt + ranks_parry + bonus_parry + effect_enhanced_parry) / 2), effective_fgt + ranks_parry + bonus_parry + effect_enhanced_parry))",
    "fortitude": "effective_sta + ranks_fortitude + bonus_fortitude + effect_enhanced_fortitude",
    "will": "effective_awe + ranks_will + bonus_will + effect_enhanced_will",
    "toughness": "effective_sta + ranks_toughness + bonus_toughness + effect_protection + if(is_defenseless, 0, if(is_vulnerable, 0, adv_defensive_roll))",

    "initiative": "effective_agl + adv_improved_initiative * 4 + bonus_initiative",

    "close_attack": "effective_fgt + adv_close_attack + bonus_close_attack",
    "ranged_attack": "effective_dex + adv_ranged_attack + bonus_ranged_attack",

    "grab_dc": "effective_str + 10",

    "unarmed_damage": "effective_str + bonus_close_damage",
    "close_damage": "max(unarmed_damage, weapon_close_damage + if(weapon_strength_based, effective_str, 0))",
    "ranged_damage": "max(0, weapon_ranged_damage + bonus_ranged_damage)",

    "skill_acrobatics": "effective_agl + ranks_acrobatics + bonus_acrobatics",
    "skill_athletics": "effective_str + ranks_athletics + bonus_athletics",
    "skill_deception": "effective_pre + ranks_deception + bonus_deception",
    "skill_expertise": "effective_int + ranks_expertise + bonus_expertise",
    "skill_insight": "effective_awe + ranks_insight + bonus_insight",
    "skill_intimidation": "effective_pre + ranks_intimidation + bonus_intimidation",
    "skill_investigation": "effective_int + ranks_investigation + bonus_investigation",
    "skill_perception": "effective_awe + ranks_perception + bonus_perception",
    "skill_persuasion": "effective_pre + ranks_persuasion + bonus_persuasion",
    "skill_sleight_of_hand": "effective_dex + ranks_sleight_of_hand + bonus_sleight_of_hand",
    "skill_stealth": "effective_agl + ranks_stealth + bonus_stealth",
    "skill_technology": "effective_int + ranks_technology + bonus_technology",
    "skill_treatment": "effective_int + ranks_treatment + bonus_treatment",
    "skill_vehicles": "effective_dex + ranks_vehicles + bonus_vehicles",

    "equipment_points": "adv_equipment * 5",

    "area_dodge": "dodge + if(adv_evasion >= 2, 5, if(adv_evasion >= 1, 2, 0))",

    "damage_resistance": "toughness - damage_penalty",

    "pl_attack_dodge": "close_attack + dodge",
    "pl_attack_parry": "close_attack + parry",
    "pl_ranged_dodge": "ranged_attack + dodge",
    "pl_dodge_toughness": "dodge + toughness",
    "pl_parry_toughness": "parry + toughness",
    "pl_fortitude_will": "fortitude + will",
    "pl_limit": "power_level * 2",
    "skill_cap": "power_level + 10"
  },

  "constraints": {
    "pl_dodge_toughness": "pl_dodge_toughness <= pl_limit",
    "pl_parry_toughness": "pl_parry_toughness <= pl_limit",
    "pl_fortitude_will": "pl_fortitude_will <= pl_limit",
    "skill_acrobatics_cap": "skill_acrobatics <= skill_cap",
    "skill_athletics_cap": "skill_athletics <= skill_cap",
    "skill_deception_cap": "skill_deception <= skill_cap",
    "skill_expertise_cap": "skill_expertise <= skill_cap",
    "skill_insight_cap": "skill_insight <= skill_cap",
    "skill_intimidation_cap": "skill_intimidation <= skill_cap",
    "skill_investigation_cap": "skill_investigation <= skill_cap",
    "skill_perception_cap": "skill_perception <= skill_cap",
    "skill_persuasion_cap": "skill_persuasion <= skill_cap",
    "skill_sleight_of_hand_cap": "skill_sleight_of_hand <= skill_cap",
    "skill_stealth_cap": "skill_stealth <= skill_cap",
    "skill_technology_cap": "skill_technology <= skill_cap",
    "skill_treatment_cap": "skill_treatment <= skill_cap",
    "skill_vehicles_cap": "skill_vehicles <= skill_cap"
  },

  "resolution": {
    "type": "degree",
    "defense_dc_offset": 10,
    "resistance_stat": "damage_resistance",
