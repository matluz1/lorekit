  "stacking": {
    "group_by": "source",
    "positive": "max",
    "negative": "min"
  },

  "end_turn": {
    "rounds": {"action": "decrement", "remove_at": 0},
    "until_escape": {"action": "escape_check", "save_stat": "skill_athletics", "save_dc_stat": "grab_dc"}
  },

  "start_turn": {
    "until_next_turn": {"action": "remove"},
    "readied": {"action": "remove"},
    "sustained": {"action": "warn"},
    "reaction": {"action": "replenish", "reset_to": 1},
    "deferred_homing": {"action": "retry_action"}
  },

  "combat": {
    "zone_scale": 1,
    "movement_unit": "rank",
    "melee_range": 0,
    "initiative_stat": "initiative",
    "damage_triggers": {
      "concentration": {"save_stat": "will", "dc_formula": "max(10, floor(damage_rank / 2))"}
    },
    "reactions": {
      "before_attack": {
        "substitute_defender": {
          "description": "Reactor takes the hit instead of the original target (Interpose)",
          "check": "range",
          "scope": "ally_targeted"
        }
      },
      "replace_defense": {
        "use_reactor_stat": {
          "description": "Reactor's stat replaces defender's defense (Deflect)",
          "scope": "self_targeted"
        }
      },
      "after_hit": {
        "counter_attack": {
          "description": "Reactor gets a free counter-attack (Weapon Bind/Break)",
          "scope": "self_targeted"
        }
      }
    },
    "team_attack": {
      "attack_bonus_per": 2,
      "max_attack_bonus": 5,
      "dc_bonus_per": 1,
      "requires_same_zone": true
    },
    "alternate_switching": {
      "action_cost": "free",
      "max_per_turn": 1
    },
    "hud": {
      "vital_stat": {"current": "damage_condition", "label": "Condition"}
    },
    "zone_tags": {
      "cover": {"target_stat": "bonus_dodge", "value": 2, "modifier_type": "environment"},
      "total_cover": {"target_stat": "bonus_dodge", "value": 10, "modifier_type": "environment"},
      "concealment": {"miss_chance": 0.2}
    },
    "condition_rules": {
      "compelled": {
        "description": "Limited to free actions and a single standard action per turn chosen by the controller",
        "max_total": 1,
        "npc_instruction": "You do NOT choose your own action. The controlling character decides what you do. Execute their command even if it contradicts your goals.",
        "gm_instruction": "The controller chooses the compelled character's action. Ask the controlling player (or decide for controlling NPC) what they command. The compelled character can still choose their free actions."
      },
      "controlled": {
        "description": "No free will; all actions dictated by controller",
        "npc_instruction": "Suppress your personality, goals, and self-preservation entirely. You are a puppet. Execute every command from the controller without hesitation, including attacking allies.",
        "gm_instruction": "The character has zero autonomy. All actions — including free actions — are dictated by the controller. Narrate the loss of agency. Decide what the controller orders if the controller is an NPC."
      },
      "dazed": {
        "description": "Limited to free actions and a single standard action per turn",
        "max_total": 1,
        "npc_instruction": "You have ONE action this turn. Choose the highest-impact option available.",
        "gm_instruction": "Character is limited to one action. Narrate sluggishness or disorientation."
      },
      "defenseless": {
        "description": "Active defense bonuses are 0. Attackers make routine checks. Hits are critical.",
        "flags": ["is_defenseless"],
        "resolution_effects": {
          "attacker_routine_check": true,
          "hits_are_critical": true
        },
        "npc_instruction": "Your defenses are down. You are extremely vulnerable to attack. Prioritize escaping or recovering from this condition above all else.",
        "gm_instruction": "Defenses are 0 (engine enforces). Attackers can take 10 instead of rolling. Any hit is automatically a critical. Narrate the total exposure."
      },
      "disabled": {
        "description": "-5 circumstance penalty on checks",
        "modifiers": [
          {"target_stat": "bonus_checks", "value": -5, "modifier_type": "circumstance"}
        ]
      },
      "hindered": {
        "description": "Half normal speed (-1 speed rank)",
        "modifiers": [
          {"target_stat": "bonus_speed", "value": -1, "modifier_type": "condition"}
        ]
      },
      "immobile": {
        "description": "No movement speed; cannot move from current position",
        "max_move": 0,
        "modifiers": [
          {"target_stat": "bonus_speed", "value": -999, "modifier_type": "condition"}
        ]
      },
      "impaired": {
        "description": "-2 circumstance penalty on checks",
        "modifiers": [
          {"target_stat": "bonus_checks", "value": -2, "modifier_type": "circumstance"}
        ]
      },
      "stunned": {
        "description": "Cannot take any actions, including free actions",
        "max_total": 0,
        "cancels_duration_types": ["sustained", "concentration"],
        "npc_instruction": "You CANNOT act at all — not even free actions. Your turn is skipped.",
        "gm_instruction": "Character cannot take any actions. Skip their turn. Sustained powers drop automatically."
      },
      "unaware": {
        "description": "Completely unaware of surroundings; unable to make interaction or Perception checks",
        "flags": ["is_unaware"]
      },
      "vulnerable": {
        "description": "Active defenses halved (round up final value)",
        "flags": ["is_vulnerable"],
        "npc_instruction": "Your defenses are halved. You are significantly easier to hit. Consider defensive actions or repositioning.",
        "gm_instruction": "Defenses halved (engine enforces via formula). Narrate the compromised guard or exposure."
      },
      "concealment": {
        "description": "Partially hidden — 50% miss chance against attacks",
        "resolution_effects": {"miss_chance": 0.5},
        "npc_instruction": "You are partially concealed. Enemies have a 50% miss chance when attacking you.",
        "gm_instruction": "Apply 50% miss chance to attacks against this character (engine enforces automatically)."
      },
      "total_concealment": {
        "description": "Fully hidden — attacks require guessing location, 50% miss chance",
        "resolution_effects": {"miss_chance": 0.5},
        "npc_instruction": "You are fully concealed. Enemies cannot see you and must guess your location.",
        "gm_instruction": "Attacker must guess target's location. If correct, 50% miss chance still applies."
      },
      "grab": {
        "description": "Immobilized — speed 0 and dodge is reduced",
        "max_move": 0,
        "modifiers": [
          {"target_stat": "bonus_dodge", "value": -2, "modifier_type": "circumstance"},
          {"target_stat": "bonus_speed", "value": -999, "modifier_type": "circumstance"}
        ]
      },
      "blind": {
        "description": "Cannot see. Hindered, visually unaware, vulnerable.",
        "components": ["hindered", "vulnerable", "unaware"],
        "npc_instruction": "You CANNOT see. Do not reference anything visual. Target enemies by sound (accept that you may miss or target the wrong location). All targets have concealment from you.",
        "gm_instruction": "Character cannot use visual information. Adjudicate whether non-visual senses can compensate. Apply concealment to all attack targets."
      },
      "bound": {
        "description": "Physically restrained and unable to move",
        "components": ["defenseless", "immobile", "impaired"]
      },
      "entranced": {
        "description": "Fascinated; takes no actions. Ends on threat or hostile action.",
        "components": ["stunned"],
        "npc_instruction": "You are captivated and cannot act voluntarily. Do nothing. If you are attacked or an ally shakes you, the trance breaks.",
        "gm_instruction": "Character is frozen in fascination. An obvious threat (attack, fire, danger) breaks the trance automatically. An ally can break it with an interaction check (DC 10 + effect rank). Narrate the fixation."
      },
      "exhausted": {
        "description": "Worse than fatigued — impaired and hindered",
        "components": ["impaired", "hindered"]
      },
      "incapacitated": {
        "description": "Knocked out; unable to act",
        "max_total": 0,
        "components": ["defenseless", "stunned", "unaware"],
        "gm_instruction": "Character is completely out of the fight. All component conditions (defenseless, stunned, unaware) apply."
      },
      "staggered": {
        "description": "Limited to one standard or move action, half speed",
        "max_total": 1,
        "components": ["dazed", "hindered"],
        "npc_instruction": "You have ONE action this turn and half speed. Choose the highest-impact option available.",
        "gm_instruction": "Character is limited to one action and half speed. Second stagger = incapacitated."
      },
      "prone": {
        "description": "Lying on ground. -5 close attacks, opponents +5 close / -5 ranged against you.",
        "components": ["hindered"],
        "extra_modifiers": [
          {"target_stat": "bonus_close_attack", "value": -5, "modifier_type": "circumstance"}
        ],
        "resolution_effects": {
          "attacker_bonus": {"melee": 5, "ranged": -5}
        },
        "npc_instruction": "You are on the ground. Standing costs a move action. While prone, your close attacks take -5 and enemies in melee get +5 against you, but ranged attacks against you take -5. Decide: stand up or stay prone.",
        "gm_instruction": "Character is on the ground. Standing up costs a move action. Apply -5 to character's close attacks and +5 to opponents' close attacks. Ranged attacks against prone target take -5."
      },
      "paralyzed": {
        "description": "Physically unable to move but may still be aware",
        "components": ["defenseless", "immobile", "stunned"],
        "gm_instruction": "Character is physically unable to move. Mental actions only (if any). Adjudicate whether mental-only actions are available."
      },
      "restrained": {
        "description": "Partially held; can still act but with difficulty",
        "components": ["hindered", "vulnerable"]
      },
      "surprised": {
        "description": "Caught off guard; lasts until first action",
        "components": ["stunned", "vulnerable"],
        "gm_instruction": "Character is caught off guard. Stunned and vulnerable until their first action."
      },
      "asleep": {
        "description": "Essentially helpless. Wakes from damage or sudden stimulus.",
        "components": ["defenseless", "stunned", "unaware"],
        "gm_instruction": "Character is asleep. Wakes from damage or sudden loud stimulus. All component conditions apply."
      },
      "deaf": {
        "description": "Cannot hear. Auditorily unaware.",
        "components": ["unaware"],
        "npc_instruction": "You CANNOT hear. Do not react to sounds, verbal commands, or spoken warnings. Communicate only through gestures or visual signals.",
        "gm_instruction": "Character cannot hear. Verbal communication fails. Surprise attacks from behind are more likely."
      },
      "dying": {
        "description": "Near death. Fortitude check DC 15 each round; failure = death.",
        "components": ["incapacitated"],
        "npc_instruction": "You are unconscious and dying. You cannot act or make decisions.",
        "gm_instruction": "Character makes a Fortitude check (DC 15) at the start of each round. Success: stable. Failure: one step closer to death — three cumulative failures = dead. An ally can stabilize with Treatment check (DC 15) or Healing effect."
      }
    },
    "combined_conditions": {
      "staggered":    { "components": ["dazed", "hindered"] },
      "exhausted":    { "components": ["impaired", "hindered"] },
      "incapacitated": { "components": ["defenseless", "stunned", "unaware"] },
      "bound":        { "components": ["defenseless", "immobile", "impaired"] },
      "paralyzed":    { "components": ["defenseless", "immobile", "stunned"] },
      "restrained":   { "components": ["hindered", "vulnerable"] },
      "surprised":    { "components": ["stunned", "vulnerable"] },
      "asleep":       { "components": ["defenseless", "stunned", "unaware"] },
      "blind":        { "components": ["hindered", "vulnerable", "unaware"] },
      "deaf":         { "components": ["unaware"] },
      "dying":        { "components": ["incapacitated"] },
      "entranced":    { "components": ["stunned"] },
      "prone":        { "components": ["hindered"], "extra_modifiers": [
        {"target_stat": "bonus_close_attack", "value": -5, "modifier_type": "circumstance"}
      ]}
    },
    "condition_thresholds": [
      {"attribute": "damage_condition", "min": 2, "condition": "dazed"},
      {"attribute": "damage_condition", "min": 3, "condition": "staggered"},
      {"attribute": "damage_condition", "min": 4, "condition": "incapacitated"}
    ]
  },

