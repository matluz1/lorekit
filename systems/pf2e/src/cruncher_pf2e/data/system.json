{
  "meta": {
    "name": "Pathfinder 2e (Remaster)",
    "dice": "d20"
  },

  "templates": {
    "source": "spells.json",
    "ability_category": "spell"
  },

  "stacking": {
    "group_by": "bonus_type",
    "positive": "max",
    "negative": "sum",
    "overrides": {
      "untyped": {"positive": "sum"},
      "_none": {"positive": "sum"}
    }
  },

  "end_turn": {
    "rounds": {"action": "decrement", "remove_at": 0},
    "until_escape": {"action": "escape_check", "save_stat": "skill_athletics", "save_dc_stat": "grab_dc"}
  },

  "combat": {
    "zone_scale": 30,
    "movement_unit": "ft",
    "melee_range": 0,
    "initiative_stat": "perception",
    "hud": {
      "vital_stat": {"current": "current_hp", "max": "max_hp", "label": "HP"}
    },
    "zone_tags": {
      "difficult_terrain": {"movement_multiplier": 2},
      "cover": {"target_stat": "bonus_ac", "value": 2, "modifier_type": "circumstance"},
      "greater_cover": {"target_stat": "bonus_ac", "value": 4, "modifier_type": "circumstance"},
      "elevated": {"target_stat": "bonus_ranged_attack", "value": 1, "modifier_type": "circumstance"}
    }
  },

  "proficiency_ranks": {
    "untrained": 0,
    "trained": 2,
    "expert": 4,
    "master": 6,
    "legendary": 8
  },

  "defaults": {
    "str": 10, "dex": 10, "con": 10, "int": 10, "wis": 10, "cha": 10,
    "ancestry_hp": 0,
    "hp_per_level": 0,
    "key_ability_mod": 0,
    "item_bonus_ac": 0,
    "armor_dex_cap": 99,
    "shield_bonus": 0,
    "speed_base": 25,
    "prof_perception": 0,
    "prof_fortitude": 0,
    "prof_reflex": 0,
    "prof_will": 0,
    "prof_class_dc": 0,
    "prof_simple_weapons": 0,
    "prof_martial_weapons": 0,
    "prof_advanced_weapons": 0,
    "prof_unarmed": 0,
    "prof_unarmored": 0,
    "prof_light_armor": 0,
    "prof_medium_armor": 0,
    "prof_heavy_armor": 0,
    "prof_spell_attack": 0,
    "prof_spell_dc": 0,
    "prof_acrobatics": 0,
    "prof_arcana": 0,
    "prof_athletics": 0,
    "prof_crafting": 0,
    "prof_deception": 0,
    "prof_diplomacy": 0,
    "prof_intimidation": 0,
    "prof_medicine": 0,
    "prof_nature": 0,
    "prof_occultism": 0,
    "prof_performance": 0,
    "prof_religion": 0,
    "prof_society": 0,
    "prof_stealth": 0,
    "prof_survival": 0,
    "prof_thievery": 0,
    "bonus_ac": 0,
    "bonus_hp": 0,
    "bonus_perception": 0,
    "bonus_fortitude": 0,
    "bonus_reflex": 0,
    "bonus_will": 0,
    "bonus_speed": 0,
    "bonus_spell_attack": 0,
    "bonus_spell_dc": 0,
    "bonus_acrobatics": 0,
    "bonus_arcana": 0,
    "bonus_athletics": 0,
    "bonus_crafting": 0,
    "bonus_deception": 0,
    "bonus_diplomacy": 0,
    "bonus_intimidation": 0,
    "bonus_medicine": 0,
    "bonus_nature": 0,
    "bonus_occultism": 0,
    "bonus_performance": 0,
    "bonus_religion": 0,
    "bonus_society": 0,
    "bonus_stealth": 0,
    "bonus_survival": 0,
    "bonus_thievery": 0,
    "bonus_melee_attack": 0,
    "bonus_ranged_attack": 0,
    "armor_check_penalty": 0,
    "armor_speed_penalty": 0
  },

  "derived": {
    "str_mod": "floor((str - 10) / 2)",
    "dex_mod": "floor((dex - 10) / 2)",
    "con_mod": "floor((con - 10) / 2)",
    "int_mod": "floor((int - 10) / 2)",
    "wis_mod": "floor((wis - 10) / 2)",
    "cha_mod": "floor((cha - 10) / 2)",

    "armor_class": "10 + min(dex_mod, armor_dex_cap) + if(prof_unarmored > 0, prof_unarmored + level, 0) + item_bonus_ac + shield_bonus + bonus_ac",
    "max_hp": "ancestry_hp + (hp_per_level + con_mod) * level + bonus_hp",
    "perception": "wis_mod + if(prof_perception > 0, prof_perception + level, 0) + bonus_perception",
    "fortitude": "con_mod + if(prof_fortitude > 0, prof_fortitude + level, 0) + bonus_fortitude",
    "reflex": "dex_mod + if(prof_reflex > 0, prof_reflex + level, 0) + bonus_reflex",
    "will": "wis_mod + if(prof_will > 0, prof_will + level, 0) + bonus_will",
    "class_dc": "10 + key_ability_mod + if(prof_class_dc > 0, prof_class_dc + level, 0)",
    "spell_attack": "key_ability_mod + if(prof_spell_attack > 0, prof_spell_attack + level, 0) + bonus_spell_attack",
    "spell_dc": "10 + key_ability_mod + if(prof_spell_dc > 0, prof_spell_dc + level, 0) + bonus_spell_dc",
    "speed": "speed_base + bonus_speed + armor_speed_penalty",

    "skill_acrobatics": "dex_mod + if(prof_acrobatics > 0, prof_acrobatics + level, 0) + bonus_acrobatics + armor_check_penalty",
    "skill_arcana": "int_mod + if(prof_arcana > 0, prof_arcana + level, 0) + bonus_arcana",
    "skill_athletics": "str_mod + if(prof_athletics > 0, prof_athletics + level, 0) + bonus_athletics + armor_check_penalty",
    "skill_crafting": "int_mod + if(prof_crafting > 0, prof_crafting + level, 0) + bonus_crafting",
    "skill_deception": "cha_mod + if(prof_deception > 0, prof_deception + level, 0) + bonus_deception",
    "skill_diplomacy": "cha_mod + if(prof_diplomacy > 0, prof_diplomacy + level, 0) + bonus_diplomacy",
    "skill_intimidation": "cha_mod + if(prof_intimidation > 0, prof_intimidation + level, 0) + bonus_intimidation",
    "skill_medicine": "wis_mod + if(prof_medicine > 0, prof_medicine + level, 0) + bonus_medicine",
    "skill_nature": "wis_mod + if(prof_nature > 0, prof_nature + level, 0) + bonus_nature",
    "skill_occultism": "int_mod + if(prof_occultism > 0, prof_occultism + level, 0) + bonus_occultism",
    "skill_performance": "cha_mod + if(prof_performance > 0, prof_performance + level, 0) + bonus_performance",
    "skill_religion": "wis_mod + if(prof_religion > 0, prof_religion + level, 0) + bonus_religion",
    "skill_society": "int_mod + if(prof_society > 0, prof_society + level, 0) + bonus_society",
    "skill_stealth": "dex_mod + if(prof_stealth > 0, prof_stealth + level, 0) + bonus_stealth + armor_check_penalty",
    "skill_survival": "wis_mod + if(prof_survival > 0, prof_survival + level, 0) + bonus_survival",
    "skill_thievery": "dex_mod + if(prof_thievery > 0, prof_thievery + level, 0) + bonus_thievery + armor_check_penalty",

    "melee_attack": "str_mod + if(prof_simple_weapons > 0, prof_simple_weapons + level, 0) + bonus_melee_attack",
    "ranged_attack": "dex_mod + if(prof_simple_weapons > 0, prof_simple_weapons + level, 0) + bonus_ranged_attack",

    "grab_dc": "class_dc"
  },

  "resolution": {
    "type": "threshold",
    "critical": {
      "natural": 20,
      "degree_shift": 1
    },
    "on_critical": {
      "damage_multiplier": 2
    }
  },
  "actions": {
    "melee_attack": {
      "attack_stat": "melee_attack",
      "defense_stat": "armor_class",
      "range": "melee",
      "on_hit": {
        "damage_roll": {"dice_attr": "weapon_damage_die", "bonus_stat": "str_mod"},
        "subtract_from": "current_hp"
      }
    },
    "ranged_attack": {
      "attack_stat": "ranged_attack",
      "defense_stat": "armor_class",
      "range": "ranged",
      "range_stat": "weapon_range",
      "on_hit": {
        "damage_roll": {"dice_attr": "weapon_damage_die", "bonus_stat": "dex_mod"},
        "subtract_from": "current_hp"
      }
    },
    "grapple": {
      "attack_stat": "skill_athletics",
      "defense_stat": "fortitude_dc",
      "range": "melee",
      "on_hit": {
        "apply_modifiers": [
          {"source": "grapple", "target_stat": "bonus_ac", "value": -2, "modifier_type": "circumstance", "duration_type": "until_escape"},
          {"source": "grapple", "target_stat": "bonus_speed", "value": -999, "modifier_type": "condition", "duration_type": "until_escape"}
        ]
      }
    },
    "shove": {
      "attack_stat": "skill_athletics",
      "defense_stat": "fortitude_dc",
      "range": "melee",
      "on_hit": {
        "push": 5,
        "push_direction": "away"
      }
    },
    "disarm": {
      "attack_stat": "skill_athletics",
      "defense_stat": "reflex_dc",
      "range": "melee",
      "on_hit": {
        "apply_modifiers": [
          {"source": "disarm", "target_stat": "bonus_melee_attack", "value": -2, "modifier_type": "circumstance", "duration_type": "until_escape"}
        ]
      }
    },
    "trip": {
      "attack_stat": "skill_athletics",
      "defense_stat": "reflex_dc",
      "range": "melee",
      "on_hit": {
        "apply_modifiers": [
          {"source": "trip", "target_stat": "bonus_ac", "value": -2, "modifier_type": "circumstance", "duration_type": "until_escape"}
        ]
      }
    }
  },

  "constraints": {
    "hp_positive": "max_hp > 0"
  },

  "build": {
    "ancestry": {
      "source": "ancestries.json",
      "select": "single",
      "writes": {"ancestry_hp": "hp", "speed_base": "speed"}
    },
    "class": {
      "source": "classes/{class}.json",
      "select": "single",
      "writes": {"hp_per_level": "meta.hp_per_level"},
      "progressions": "meta.progressions"
    },
    "feat": {
      "source": "feats.json",
      "select": "multiple",
      "effects": true
    },
    "armor": {
      "source": "equipment.json",
      "select": "equipped",
      "catalog_path": "armor",
      "writes": {
        "item_bonus_ac": "ac_bonus",
        "armor_dex_cap": "dex_cap",
        "armor_check_penalty": "check_penalty",
        "armor_speed_penalty": "speed_penalty"
      }
    },
    "shield": {
      "source": "equipment.json",
      "select": "equipped",
      "catalog_path": "shields",
      "writes": {
        "shield_bonus": "ac_bonus"
      }
    },
    "weapon": {
      "source": "equipment.json",
      "select": "equipped",
      "catalog_path": "weapons",
      "writes": {
        "weapon_damage_die": "damage_die",
        "weapon_damage_type": "damage_type",
        "weapon_group": "group",
        "weapon_traits": "traits"
      }
    }
  },

  "encounter_end": {
    "clear_duration_types": [
      "encounter", "rounds", "concentration",
      "until_next_turn", "reaction"
    ]
  },

  "rest": {
    "short": {
      "restore": {"current_hp": "current_hp"},
      "reset_uses": ["per_encounter"],
      "clear_duration_types": ["encounter"]
    },
    "long": {
      "restore": {"current_hp": "max_hp"},
      "reset_uses": ["per_day", "per_encounter"],
      "clear_duration_types": ["encounter", "rounds", "save_ends"],
      "time_advance": {"amount": 8, "unit": "hours"}
    }
  },

  "intent": {
    "steps": {
      "move": {
        "field": "move_to",
        "field_type": "zone",
        "multi": true,
        "executor": "movement"
      },
      "action": {
        "executor": "resolve_action",
        "fields": {
          "action": { "type": "action_name", "nullable": true },
          "targets": { "type": "characters", "nullable": true }
        }
      }
    },
    "default_sequence": ["move", "action"],
    "sequence_rules": {
      "max_per_step": { "move": 1, "action": 1 },
      "max_total": 2
    },
    "extra_fields": {
      "narration": { "type": "text", "nullable": true }
    },
    "rules": [
      "sequence defines execution order — reorder steps as tactics demand",
      "Most turns use at most one move and one action",
      "action MUST be one of the available actions — NOT an ability name",
      "action/targets/move_to can all be null (narrative-only turn)"
    ]
  },

  "encounter_templates": {
    "tavern_brawl": {
      "zones": [
        {"name": "Bar", "tags": ["cover"]},
        {"name": "Common Room", "tags": []},
        {"name": "Kitchen", "tags": ["difficult_terrain"]},
        {"name": "Street", "tags": []}
      ],
      "adjacency": [["Bar", "Common Room", 1], ["Common Room", "Kitchen", 1], ["Common Room", "Street", 1]]
    },
    "dungeon_corridor": {
      "zones": [
        {"name": "Entrance", "tags": []},
        {"name": "Hallway", "tags": []},
        {"name": "Chamber", "tags": []}
      ],
      "adjacency": [["Entrance", "Hallway", 1], ["Hallway", "Chamber", 1]]
    },
    "open_field": {
      "zones": [
        {"name": "North", "tags": []},
        {"name": "Center", "tags": []},
        {"name": "South", "tags": []}
      ],
      "adjacency": [["North", "Center", 1], ["Center", "South", 1]]
    },
    "forest_ambush": {
      "zones": [
        {"name": "Trail", "tags": []},
        {"name": "Dense Trees", "tags": ["cover", "difficult_terrain"]},
        {"name": "Clearing", "tags": []},
        {"name": "Ridge", "tags": ["elevated"]}
      ],
      "adjacency": [["Trail", "Dense Trees", 1], ["Dense Trees", "Clearing", 1], ["Clearing", "Ridge", 1], ["Trail", "Clearing", 2]]
    }
  }
}
